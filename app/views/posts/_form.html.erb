<hr>
<%= form_with model: @post, local: true, id: 'post-form' do |form| %>
  <%= form.date_field :date, :style => 'display:inline;', :value => @post.datetime.strftime("%Y-%m-%d"), type: (@show_date ? :date : :hidden) %>
  <%= form.time_field :time, :style => 'display:inline;', :value => @post.datetime.strftime("%H:%M"), type: (@show_date ? :time : :hidden) %>

  <div id="drop-zone" class="drop-zone">
    <%= form.text_area :content, :rows => 10, :dir => "auto", :style => 'display:block;width:100%;', :oninput => "doRender()", :value => @post.content %>
    <div class="drop-zone-hint">Drop images here</div>
  </div>

  <noscript>
    <%= form.file_field :pic, :accept => "image/*,.heic,.heif,.mp4,.mov,.hevc,.mp3", :style => "display:inline;" %>
    <%= form.submit :value => "Upload Selected Image", data: {disable_with: "Upload Selected Image"}, :style => "display:inline;" %>
  </noscript>

  <div class="upload-controls">
    <input type="file" id="upload-file-input" accept="image/*,.heic,.heif,.mp4,.mov,.hevc,.mp3" multiple style="display:none;">
    <button type="button" id="upload-btn" class="upload-btn">
      &#128247; Add Photo
    </button>
    <span id="upload-indicator" class="upload-indicator" style="display:none;">
      <span class="spinner"></span> Uploading&hellip;
    </span>
    <progress id="upload-progress" max="100" value="0" style="display:none;" class="upload-progress"></progress>
  </div>

  <%= form.submit :value => "Save Post", :style => "display:block;" %>
  <span id="draft-status" style="font-size:0.85em; color:#888;"></span>
<% end %>

<%= link_to "Markdown", "/markdown", target: "_blank" %> Preview:
<hr>


<div id="display" dir="auto">
</div>

<%= javascript_tag nonce: true, type: 'application/javascript' do %>

var draftKey = "<%= @post.persisted? ? "haven_draft_#{@post.id}" : 'haven_draft_new' %>";
var serverContent = document.getElementById("post_content").value;
var _draftTimer = null;

function doRender() {
  var converter = new showdown.Converter();
  converter.setFlavor('github');
  var text      = document.getElementById("post_content").value;
  var html      = converter.makeHtml(text);
  document.getElementById("display").innerHTML = html;
}

function saveDraft() {
  clearTimeout(_draftTimer);
  _draftTimer = setTimeout(function() {
    try {
      localStorage.setItem(draftKey, document.getElementById("post_content").value);
      var el = document.getElementById("draft-status");
      el.textContent = "Draft saved";
      setTimeout(function() { if (el.textContent === "Draft saved") el.textContent = ""; }, 2000);
    } catch(e) {}
  }, 500);
}

function clearDraft() {
  try { localStorage.removeItem(draftKey); } catch(e) {}
}

function discardDraft() {
  clearDraft();
  document.getElementById("post_content").value = serverContent;
  doRender();
  document.getElementById("draft-status").innerHTML = "";
}

function restoreDraft() {
  try {
    var draft = localStorage.getItem(draftKey);
    if (draft !== null && draft !== serverContent) {
      document.getElementById("post_content").value = draft;
      doRender();
      document.getElementById("draft-status").innerHTML =
        'Draft restored. <a href="#" onclick="discardDraft(); return false;">Discard</a>';
    }
  } catch(e) {}
}

document.getElementById("post_content").addEventListener("input", saveDraft);
document.getElementById("post-form").addEventListener("submit", clearDraft);
restoreDraft();
doRender();

function setTime() {
  var today = new Date();
  var dd = String(today.getDate()).padStart(2, '0');
  var mm = String(today.getMonth() + 1).padStart(2, '0'); //January is 0!
  var yyyy = today.getFullYear().toString();
  var dateString = yyyy + "-" + mm + "-" + dd;
  var hh = String(today.getHours()).padStart(2, '0');
  var mm = String(today.getMinutes()).padStart(2, '0');
  var timeString = hh + ":" + mm;
  document.getElementById("post_date").value = dateString;
  document.getElementById("post_time").value = timeString;
}
if (document.getElementById("post_content").value.trim()=="") {
  setTime();
}
<% end %>
